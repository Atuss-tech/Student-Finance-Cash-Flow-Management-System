<UserControl x:Class="WPF.Features.Dashboard.DashboardHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Features.Dashboard"
             xmlns:transactions="clr-namespace:WPF.Features.Transactions"
             xmlns:budget="clr-namespace:WPF.Features.Budget"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">
    <UserControl.Resources>
        <!-- Stitch AI Design System Colors -->
                                <SolidColorBrush x:Key="AppBackground" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0052ff"/>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#003ecc"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryLightGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="IncomeColor" Color="#05b169"/>
        <SolidColorBrush x:Key="IncomePurple" Color="#05b169"/>
        <SolidColorBrush x:Key="ExpenseColor" Color="#cf202f"/>
        <SolidColorBrush x:Key="ExpenseRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="SavingsOrange" Color="#0052ff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e5e7eb"/>
        
        <Style x:Key="StitchCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
        <Grid Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== ROW 0: 4 KPI Cards ========== -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- KPI 1: Balance -->
                <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0">
                    <Grid>
                        <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource PrimaryLightGreen}" CornerRadius="0,0,24,24"/>
                        <StackPanel Margin="20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="SỐ DƯ HIỆN TẠI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="↑ 8.2%" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryLightGreen}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="127.5Mđ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Tất cả tài khoản" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KPI 2: Income -->
                <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,10,0">
                    <Grid>
                        <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource IncomePurple}" CornerRadius="0,0,24,24"/>
                        <StackPanel Margin="20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="THU NHẬP THÁNG" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="↑ 12.4%" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryLightGreen}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="33.0Mđ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KPI 3: Expense -->
                <Border Grid.Column="2" Style="{StaticResource StitchCard}" Margin="10,0,10,0">
                    <Grid>
                        <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource ExpenseRed}" CornerRadius="0,0,24,24"/>
                        <StackPanel Margin="20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="CHI TIÊU THÁNG" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="↓ 3.1%" FontSize="12" FontWeight="Bold" Foreground="{StaticResource ExpenseRed}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="11.8Mđ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KPI 4: Savings -->
                <Border Grid.Column="3" Style="{StaticResource StitchCard}" Margin="10,0,0,0">
                    <Grid>
                        <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource SavingsOrange}" CornerRadius="0,0,24,24"/>
                        <StackPanel Margin="20">
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="TIẾT KIỆM" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                <TextBlock Text="↑ 5.7%" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PrimaryLightGreen}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="21.3Mđ" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Mục tiêu: 30Mđ" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== ROW 1: Charts ========== -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Area Chart Card -->
                <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Dòng tiền 12 tháng" FontWeight="Bold" FontSize="20"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Thu nhập &amp; Chi tiêu theo tháng" FontSize="14"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource PrimaryLightGreen}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Thu nhập" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" Margin="0,0,20,0" VerticalAlignment="Center"/>
                                <Ellipse Width="8" Height="8" Fill="{StaticResource IncomePurple}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Chi tiêu" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ChartSeries}"
                                            XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                            TooltipPosition="Top" AnimationsSpeed="00:00:00.4"/>
                    </Grid>
                </Border>

                <!-- Donut Chart Card -->
                <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,0,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="300"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,24">
                            <TextBlock Text="Phân bổ chi tiêu" FontWeight="Bold" FontSize="20"
                                       Foreground="{StaticResource TextPrimary}"/>
                            <TextBlock Text="Tháng 7/2026" FontSize="14"
                                       Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:PieChart Grid.Row="1" Series="{Binding ExpenseAllocationSeries}"
                                      LegendPosition="Bottom" AnimationsSpeed="00:00:01.0"
                                      LegendTextPaint="{Binding ChartLegendTextPaint}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== ROW 2: Transactions + Budgets ========== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Transactions -->
                <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Giao dịch gần đây" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                            </StackPanel>
                            <Button Content="Xem tất cả" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource PrimaryLightGreen}"
                                    Command="{Binding ShowTransactionsCommand}" Cursor="Hand"
                                    FontWeight="SemiBold" FontSize="14"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding RecentTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,16" Background="Transparent" Cursor="Hand">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Icon -->
                                            <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24" Background="#e6f0ff" Margin="0,0,16,0">
                                                <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                            </Border>
                                            
                                            <!-- Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding CategoryName}" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                            
                                            <!-- Amount -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding FormattedAmount}" FontWeight="Bold" FontSize="15" Foreground="{Binding AmountColorBrush, FallbackValue=#ffffff}" HorizontalAlignment="Right" Margin="0,0,0,4"/>
                                                <TextBlock Text="{Binding DateString}" FontSize="12" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Budget Progress -->
                <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,0,0" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Ngân sách tháng" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="14"
                                           Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Width="36" Height="36" Background="{StaticResource PrimaryBlue}"
                                    CornerRadius="18" Cursor="Hand">
                                <TextBlock Text="+" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="20"/>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MaxHeight="400">
                            <ItemsControl ItemsSource="{Binding BudgetProgresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,24">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Category name + amounts -->
                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                    <Border Width="32" Height="32" CornerRadius="16" Background="#e6f0ff" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Icon}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="15"
                                                               Foreground="{StaticResource TextPrimary}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FormattedSpent}" Foreground="{StaticResource TextPrimary}"
                                                               FontSize="14" FontWeight="Bold"/>
                                                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="14"/>
                                                    <TextBlock Text="{Binding FormattedTotal}" Foreground="{StaticResource TextSecondary}"
                                                               FontSize="14"/>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Progress bar -->
                                            <ProgressBar Grid.Row="1" Height="8" Minimum="0" Maximum="100"
                                                         Value="{Binding AnimatedProgress, Mode=OneWay}"
                                                         Foreground="{Binding ProgressBrush, FallbackValue=#0052ff}"
                                                         Background="#e6f0ff" BorderThickness="0">
                                                <ProgressBar.Template>
                                                    <ControlTemplate TargetType="ProgressBar">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" ClipToBounds="True">
                                                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </ProgressBar.Template>
                                            </ProgressBar>

                                            <!-- Status text + percentage -->
                                            <Grid Grid.Row="2" Margin="0,8,0,0">
                                                <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondary}"
                                                           HorizontalAlignment="Left"/>
                                                <TextBlock HorizontalAlignment="Right" FontSize="12" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold">
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>


