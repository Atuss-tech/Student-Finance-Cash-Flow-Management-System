<UserControl x:Class="WPF.Features.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Stitch AI Design System Colors -->
                                <SolidColorBrush x:Key="AppBackground" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0052ff"/>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#003ecc"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryLightGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="IncomeColor" Color="#05b169"/>
        <SolidColorBrush x:Key="IncomePurple" Color="#05b169"/>
        <SolidColorBrush x:Key="ExpenseColor" Color="#cf202f"/>
        <SolidColorBrush x:Key="ExpenseRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="SavingsOrange" Color="#0052ff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e5e7eb"/>

        <Style x:Key="StitchCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="#f0f2f5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="100" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#f0f2f5"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="100" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource FadeInSlideUpAnimation}"/>
            </EventTrigger>
        </Grid.Triggers>
        <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Left: Avatar & Info -->
                        <ColumnDefinition Width="3*"/>
                        <!-- Right: Settings & Password -->
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Left Profile Card ── -->
                    <Border Grid.Column="0" Style="{StaticResource StitchCard}" VerticalAlignment="Top" Margin="0,0,20,0" Padding="24">
                        <StackPanel>
                            <!-- Avatar -->
                            <Border Width="100" Height="100" CornerRadius="50" Background="{StaticResource IncomePurple}" Margin="0,10,0,20" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AvatarInitials}" Foreground="#f0f2f5" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Basic Info -->
                            <TextBlock Text="{Binding FullName}" Foreground="{StaticResource TextPrimary}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Email}" Foreground="{StaticResource TextSecondary}" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,20"/>

                            <!-- Plan Info -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#e6f0ff" Margin="0,0,12,0">
                                    <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Gói tài khoản" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="{Binding SubscriptionPlan}" Foreground="{StaticResource SavingsOrange}" FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="#e6f0ff" Margin="0,0,12,0">
                                    <TextBlock Text="☁️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Dung lượng dữ liệu" Foreground="{StaticResource TextSecondary}" FontSize="13"/>
                                    <TextBlock Text="{Binding TotalDataSize}" Foreground="{StaticResource TextPrimary}" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding JoinDate}" Foreground="{StaticResource TextSecondary}" FontSize="12" HorizontalAlignment="Center" Margin="0,20,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Right Setting Cards ── -->
                    <StackPanel Grid.Column="1">
                        
                        <!-- Personal Info -->
                        <Border Style="{StaticResource StitchCard}" Margin="0,0,0,20" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Thông tin cá nhân" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,10,15">
                                        <TextBlock Text="Họ và tên" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,15">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,24">
                                    <TextBlock Text="Email" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Foreground="{StaticResource TextSecondary}"/>
                                </StackPanel>

                                <Button Content="Cập nhật thông tin" Background="{StaticResource PrimaryLightGreen}" Foreground="#f0f2f5"
                                        FontWeight="Bold" Padding="20,12" HorizontalAlignment="Right" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Change Password -->
                        <Border Style="{StaticResource StitchCard}" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Đổi mật khẩu" Foreground="{StaticResource TextPrimary}" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>
                                
                                <!-- Alert Box -->
                                <Border Margin="0,0,0,15" Padding="12" CornerRadius="6" Visibility="{Binding HasAlert, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#264edea3"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryLightGreen}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlertError}" Value="True">
                                                    <Setter Property="Background" Value="#26ffb4ab"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource ExpenseRed}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding AlertMessage}" TextWrapping="Wrap" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource PrimaryLightGreen}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlertError}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ExpenseRed}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="OldPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Mật khẩu mới" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="NewPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,24">
                                    <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <Button Content="Lưu mật khẩu mới" Command="{Binding ChangePasswordCommand}" 
                                        Background="#e6f0ff" Foreground="{StaticResource TextPrimary}"
                                        FontWeight="Bold" Padding="20,12" HorizontalAlignment="Right" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2a425c"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>


