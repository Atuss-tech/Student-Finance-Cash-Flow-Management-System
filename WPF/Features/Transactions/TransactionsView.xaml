<UserControl x:Class="WPF.Features.Transactions.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Features.Transactions"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Stitch AI Design System Colors -->
                                <SolidColorBrush x:Key="AppBackground" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0052ff"/>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#003ecc"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryLightGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="IncomeColor" Color="#05b169"/>
        <SolidColorBrush x:Key="IncomePurple" Color="#05b169"/>
        <SolidColorBrush x:Key="ExpenseColor" Color="#cf202f"/>
        <SolidColorBrush x:Key="ExpenseRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="SavingsOrange" Color="#0052ff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e5e7eb"/>
        
        <Style x:Key="StitchCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Detail panel -->
            <ColumnDefinition Width="{Binding DetailPanelWidth}"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ MAIN COLUMN ══════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>
                
                <!-- ── 3 Stat Mini Cards ── -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="#3b82f6" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="TỔNG GIAO DỊCH" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardTotal.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardTotal.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Income -->
                    <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,10,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource PrimaryLightGreen}" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="TỔNG THU" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardIncome.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryLightGreen}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardIncome.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Expense -->
                    <Border Grid.Column="2" Style="{StaticResource StitchCard}" Margin="10,0,0,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource ExpenseRed}" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="TỔNG CHI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardExpense.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ExpenseRed}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardExpense.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Bar Chart + Range ── -->
                <Border Style="{StaticResource StitchCard}" Margin="0,0,0,24" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="250"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Biểu đồ Giao dịch hàng ngày" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Thu nhập vs Chi tiêu theo ngày" FontSize="14" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <!-- Range buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border Background="#e6f0ff" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                                    <TextBlock Text="7 ngày" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13"/>
                                </Border>
                                <Border Background="{StaticResource PrimaryLightGreen}" CornerRadius="6" Padding="12,6" Margin="0,0,8,0" Cursor="Hand">
                                    <TextBlock Text="30 ngày" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="13"/>
                                </Border>
                                <Border Background="#e6f0ff" CornerRadius="6" Padding="12,6" Cursor="Hand">
                                    <TextBlock Text="3 tháng" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="13"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ChartSeries}"
                                            XAxes="{Binding ChartXAxes}" YAxes="{Binding ChartYAxes}"
                                            TooltipPosition="Top" AnimationsSpeed="00:00:00.5"
                                            LegendPosition="Right"
                                            LegendTextPaint="{Binding ChartLegendTextPaint}"/>
                    </Grid>
                </Border>

                <!-- ── Filters Row ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Search box -->
                    <Border Grid.Column="0" Background="#ffffff" BorderThickness="0" CornerRadius="24" Width="200" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" Width="150" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Category Pills -->
                    <ItemsControl Grid.Column="1" ItemsSource="{Binding CategoryPills}" Margin="16,0,0,0" VerticalAlignment="Center">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel VerticalAlignment="Center"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{Binding PillBackground, FallbackValue=#ffffff}" CornerRadius="24" Padding="16,8" Margin="0,0,8,0" Cursor="Hand">
                                    <TextBlock Text="{Binding Name}" Foreground="{Binding PillForeground, FallbackValue=#ffffff}" FontWeight="SemiBold" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Grid>

                <!-- ── Transaction List Grouped by Date ── -->
                <ItemsControl ItemsSource="{Binding GroupedList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Date Group -->
                            <Border Style="{StaticResource StitchCard}" Margin="0,0,0,16" Padding="0">
                                <StackPanel>
                                    <!-- Group header -->
                                    <Border Background="#f3f4f6" Padding="24,12" CornerRadius="12,12,0,0">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="📅" FontSize="15" Margin="0,0,8,0" Foreground="{StaticResource TextSecondary}"/>
                                                <TextBlock Text="{Binding DateLabel}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding DayTotal}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Foreground="{Binding TotalBrush}"/>
                                        </Grid>
                                    </Border>

                                    <!-- Transactions in group -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,0,1" Padding="24,16" Cursor="Hand" MouseLeftButtonDown="SelectTransaction_Click">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0d1c2d"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="4*"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="2*"/>
                                                                <ColumnDefinition Width="2*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Grid.Column="0" CornerRadius="100" Background="{Binding IconBackground, FallbackValue=#e6f0ff}" Margin="0,0,16,0" Width="36" Height="36">
                                                                <TextBlock Text="{Binding Icon}" Foreground="{Binding AmountColorBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                                            </Border>

                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" />
                                                                    <TextBlock Text=" - " FontSize="14" Foreground="{StaticResource TextSecondary}" />
                                                                    <TextBlock Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextSecondary}" />
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <Border Grid.Column="2" Background="{Binding StatusBackground}" CornerRadius="24" Padding="12,4" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Status}" FontSize="12" FontWeight="SemiBold" Foreground="{Binding StatusForeground}"/>
                                                            </Border>

                                                            <TextBlock Grid.Column="3" Text="{Binding Category}" FontSize="14" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>

                                                            <TextBlock Grid.Column="4" Text="{Binding FormattedAmount}" FontSize="15" FontWeight="Bold" Foreground="{Binding AmountColorBrush, FallbackValue=#ffffff}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                        </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Pagination ── -->
                <Border Style="{StaticResource StitchCard}" Padding="20,16" Margin="0,0,0,24">
                    <Grid>
                        <Border HorizontalAlignment="Left" Background="#e6f0ff" CornerRadius="100" Padding="16,8" Cursor="Hand">
                            <TextBlock Text="← Trước" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                        </Border>
                        <TextBlock Text="{Binding PageLabel}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextSecondary}"/>
                        <Border HorizontalAlignment="Right" Background="#e6f0ff" CornerRadius="100" Padding="16,8" Cursor="Hand">
                            <TextBlock Text="Sau →" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════ DETAIL PANEL ══════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource SurfaceColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1,0,0,0" Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVis}}" Padding="32">
            <Border.RenderTransform>
                <TranslateTransform X="0"/>
            </Border.RenderTransform>

            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel DataContext="{Binding SelectedTransaction}">
                    <!-- Header -->
                    <Grid Margin="0,0,0,32">
                        <TextBlock Text="Chi tiết Giao dịch" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}" FontSize="20" Cursor="Hand" Click="CloseDetail_Click"/>
                    </Grid>

                    <!-- Big icon + title -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,32">
                        <Border Width="88" Height="88" CornerRadius="44" Background="#e6f0ff" HorizontalAlignment="Center" Margin="0,0,0,16">
                            <TextBlock Text="{Binding Icon}" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Title}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Category}" FontSize="15" Foreground="{StaticResource TextSecondary}" TextAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Big amount -->
                    <TextBlock Text="{Binding FormattedAmount}" FontSize="40" FontWeight="Bold" Foreground="{Binding AmountColorBrush, FallbackValue=#ffffff}" TextAlignment="Center" Margin="0,0,0,32"/>

                    <!-- Detail rows -->
                    <Border Background="#f3f4f6" CornerRadius="24" Padding="24" Margin="0,0,0,32">
                        <StackPanel>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Ngày" Foreground="{StaticResource TextSecondary}" FontSize="15"/>
                                <TextBlock Text="{Binding Date, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Foreground="{StaticResource TextPrimary}" FontSize="15" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>
                            <Grid Margin="0,0,0,16">
                                <TextBlock Text="Danh mục" Foreground="{StaticResource TextSecondary}" FontSize="15"/>
                                <TextBlock Text="{Binding Category}" Foreground="{StaticResource TextPrimary}" FontSize="15" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Border Height="1" Background="{StaticResource BorderColor}" Margin="0,0,0,16"/>
                            <Grid>
                                <TextBlock Text="Loại" Foreground="{StaticResource TextSecondary}" FontSize="15"/>
                                <TextBlock Foreground="{Binding AmountColorBrush, FallbackValue=#ffffff}" FontSize="15" FontWeight="Bold" HorizontalAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="IsExpense">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="#e6f0ff" Cursor="Hand" Margin="0,0,8,0" Click="EditTransaction_Click" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="100" Padding="0,16">
                                        <TextBlock Text="✏️ Sửa" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Grid.Column="1" Background="#cf202f" Cursor="Hand" Margin="8,0,0,0" Click="DeleteTransaction_Click" BorderThickness="0" Padding="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="100" Padding="0,16">
                                        <TextBlock Text="🗑️ Xóa" Foreground="#8c1d18" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>


