<UserControl x:Class="WPF.Features.Budget.BudgetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Features.Budget"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Stitch AI Design System Colors -->
                                <SolidColorBrush x:Key="AppBackground" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0052ff"/>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#003ecc"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryLightGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="IncomeColor" Color="#05b169"/>
        <SolidColorBrush x:Key="IncomePurple" Color="#05b169"/>
        <SolidColorBrush x:Key="ExpenseColor" Color="#cf202f"/>
        <SolidColorBrush x:Key="ExpenseRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="SavingsOrange" Color="#0052ff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e5e7eb"/>
        
        <Style x:Key="StitchCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>

                <!-- ── 4 Stat Mini Cards ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Budget -->
                    <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="#3b82f6" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="TỔNG NGÂN SÁCH" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardTotalBudget.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimary}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardTotalBudget.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Spent -->
                    <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,10,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource ExpenseRed}" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="ĐÃ CHI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardSpent.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource ExpenseRed}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardSpent.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Remaining -->
                    <Border Grid.Column="2" Style="{StaticResource StitchCard}" Margin="10,0,10,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource PrimaryLightGreen}" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="CÒN LẠI" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardRemaining.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryLightGreen}" Margin="0,6,0,4"/>
                                <TextBlock Text="Tháng 7/2026" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardRemaining.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <!-- Saving Rate -->
                    <Border Grid.Column="3" Style="{StaticResource StitchCard}" Margin="10,0,0,0">
                        <Grid>
                            <Border Height="4" VerticalAlignment="Bottom" Background="{StaticResource IncomePurple}" CornerRadius="0,0,24,24"/>
                            <StackPanel HorizontalAlignment="Left" Margin="20">
                                <TextBlock Text="TỶ LỆ TIẾT KIỆM" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondary}"/>
                                <TextBlock Text="{Binding CardSavingRate.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource IncomePurple}" Margin="0,6,0,4"/>
                                <TextBlock Text="Mục tiêu: 20%" FontSize="13" Foreground="{StaticResource TextSecondary}"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Width="44" Height="44" CornerRadius="24" Background="#e6f0ff">
                                <TextBlock Text="{Binding CardSavingRate.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Alert Banner (If Overbudget) ── -->
                <Border Background="#fff0f2" BorderBrush="{StaticResource ExpenseRed}" BorderThickness="1" CornerRadius="24"
                        Padding="16,12" Margin="0,0,0,20" Visibility="{Binding HasAlert, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="⚠️" FontSize="20" Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding AlertMessage}" Foreground="{StaticResource ExpenseRed}"
                                   FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="14"/>
                    </Grid>
                </Border>

                <!-- ── Charts Row (Donut, Bar, Area) ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Donut Overall -->
                    <Border Grid.Column="0" Style="{StaticResource StitchCard}" Margin="0,0,10,0" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Tổng quan" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <lvc:PieChart Grid.Row="1" Series="{Binding DonutSeries}" AnimationsSpeed="00:00:01.0"
                                          LegendPosition="Bottom" LegendTextPaint="{Binding ChartLegendTextPaint}" Height="200"/>
                        </Grid>
                    </Border>

                    <!-- Bar Chart (Budget vs Actual) -->
                    <Border Grid.Column="1" Style="{StaticResource StitchCard}" Margin="10,0,10,0" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Ngân sách vs Thực chi" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding BarChartSeries}" XAxes="{Binding BarChartXAxes}" YAxes="{Binding BarChartYAxes}"
                                                TooltipPosition="Top" AnimationsSpeed="00:00:00.5" LegendPosition="Bottom" LegendTextPaint="{Binding ChartLegendTextPaint}" Height="200"/>
                        </Grid>
                    </Border>

                    <!-- Area Chart (6 month trend) -->
                    <Border Grid.Column="2" Style="{StaticResource StitchCard}" Margin="10,0,0,0" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Xu hướng 6 tháng" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding AreaChartSeries}" XAxes="{Binding AreaChartXAxes}" YAxes="{Binding AreaChartYAxes}"
                                                TooltipPosition="Top" AnimationsSpeed="00:00:00.5" LegendPosition="Bottom" LegendTextPaint="{Binding ChartLegendTextPaint}" Height="200"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── AI Suggestion Banner ── -->
                <Border Style="{StaticResource StitchCard}" Padding="24" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="🧠" FontSize="32" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Phân tích từ FinanceAI" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock Text="Tháng này bạn đã tiêu nhiều hơn 15% vào 'Giải trí' so với tháng trước. Nên cân nhắc điều chỉnh ngân sách hoặc cắt giảm chi tiêu tuần cuối để đảm bảo an toàn."
                                       Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="14"/>
                        </StackPanel>
                        <Border Grid.Column="2" Background="{StaticResource PrimaryGreen}" CornerRadius="100" Padding="16,10" Cursor="Hand" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock Text="Tối ưu ngay" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ── Category Budget Grid ── -->
                <TextBlock Text="Chi tiết Danh mục" FontWeight="Bold" FontSize="20" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,16"/>
                <ItemsControl ItemsSource="{Binding AllBudgets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StitchCard}" Margin="0,0,16,16" Padding="24">
                                <Grid>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Category name + amounts -->
                                        <Grid Grid.Row="0" Margin="0,0,0,16">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                <Border Width="36" Height="36" CornerRadius="100" Background="#e6f0ff" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding Icon}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                </Border>
                                                <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="16"
                                                           Foreground="{StaticResource TextPrimary}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding FormattedSpent}" Foreground="{StaticResource TextPrimary}"
                                                           FontSize="15" FontWeight="Bold"/>
                                                <TextBlock Text=" / " Foreground="{StaticResource TextSecondary}" FontSize="15"/>
                                                <TextBlock Text="{Binding FormattedTotal}" Foreground="{StaticResource TextSecondary}"
                                                           FontSize="15"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Progress bar -->
                                        <ProgressBar Grid.Row="1" Height="8" Minimum="0" Maximum="100"
                                                     Value="{Binding AnimatedProgress, Mode=OneWay}"
                                                     Foreground="{Binding ProgressBrush, FallbackValue=#0052ff}"
                                                     Background="#e6f0ff" BorderThickness="0">
                                            <ProgressBar.Template>
                                                <ControlTemplate TargetType="ProgressBar">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4" ClipToBounds="True">
                                                        <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" CornerRadius="4" HorizontalAlignment="Left"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </ProgressBar.Template>
                                        </ProgressBar>

                                        <!-- Status text + percentage -->
                                        <Grid Grid.Row="2" Margin="0,10,0,0">
                                            <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Left"/>
                                            <TextBlock HorizontalAlignment="Right" FontSize="13" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold">
                                                <Run Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0:0}}"/>
                                                <Run Text="%"/>
                                            </TextBlock>
                                        </Grid>
                                    </Grid>
                                    <!-- Edit Button (overlay on top right) -->
                                    <Button Content="⋮" HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}"
                                            FontSize="20" FontWeight="Bold" Cursor="Hand" Margin="-8,-8,0,0"
                                            Click="OpenEdit_Click"
                                            CommandParameter="{Binding}">
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════ EDIT MODAL OVERLAY ══════════════════ -->
        <Grid Visibility="{Binding IsEditModalOpen, Converter={StaticResource BoolToVis}}">
            <!-- Background Overlay (Click to close) -->
            <Border Background="#80000000" MouseLeftButtonDown="CloseEdit_Click"/>
            
            <!-- Modal Box -->
            <Border Background="{StaticResource SurfaceColor}" BorderBrush="{StaticResource BorderColor}" BorderThickness="1"
                    CornerRadius="24" Width="440" HorizontalAlignment="Center" VerticalAlignment="Center"
                    Padding="32">
                <Border.RenderTransform>
                    <TranslateTransform Y="0"/>
                </Border.RenderTransform>

                <StackPanel DataContext="{Binding EditingBudget}">
                    <Grid Margin="0,0,0,32">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Icon}" FontSize="28" Margin="0,0,16,0"/>
                            <TextBlock Text="Chỉnh sửa ngân sách" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                                BorderThickness="0" Foreground="{StaticResource TextSecondary}"
                                FontSize="20" Cursor="Hand"
                                Click="CloseEdit_Click"/>
                    </Grid>

                    <TextBlock Text="Danh mục" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,8"/>
                    <Border Background="#f3f4f6" CornerRadius="100" Padding="16" Margin="0,0,0,24">
                        <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="16"/>
                    </Border>

                    <TextBlock Text="Số tiền ngân sách (VND)" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,8"/>
                    <Border Background="#f3f4f6" BorderBrush="{StaticResource PrimaryLightGreen}" BorderThickness="1" CornerRadius="100" Padding="16" Margin="0,0,0,24">
                        <TextBox Text="{Binding TotalAmount, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:N0}}"
                                 Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}"
                                 FontWeight="Bold" FontSize="18" CaretBrush="{StaticResource PrimaryLightGreen}"/>
                    </Border>

                    <TextBlock Text="Chu kỳ" Foreground="{StaticResource TextSecondary}" FontSize="14" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <RadioButton Grid.Column="0" Content="Hàng ngày" GroupName="Period" Foreground="{StaticResource TextPrimary}" Margin="0,0,8,0" FontSize="14"/>
                        <RadioButton Grid.Column="1" Content="Hàng tuần" GroupName="Period" Foreground="{StaticResource TextPrimary}" Margin="8,0,8,0" FontSize="14"/>
                        <RadioButton Grid.Column="2" Content="Hàng tháng" GroupName="Period" Foreground="{StaticResource TextPrimary}" IsChecked="True" Margin="8,0,0,0" FontSize="14"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="#e6f0ff" CornerRadius="100" Margin="0,0,8,0" Padding="0,14" Cursor="Hand" MouseLeftButtonDown="CloseEdit_Click">
                            <TextBlock Text="Hủy" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                        </Border>
                        <Border Grid.Column="1" Background="{StaticResource PrimaryGreen}" CornerRadius="100" Margin="8,0,0,0" Padding="0,14" Cursor="Hand" MouseLeftButtonDown="SaveEdit_Click">
                            <TextBlock Text="Lưu thay đổi" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="15"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>


