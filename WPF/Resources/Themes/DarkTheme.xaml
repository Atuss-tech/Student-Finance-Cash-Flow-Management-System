<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme Colors (FinanceOS Premium Dark) -->
    <Color x:Key="AppBackground">#080a0f</Color>
    <Color x:Key="SidebarBackground">#05070a</Color>
    <Color x:Key="CardBackground">#0d111a</Color>
    <Color x:Key="CardBorder">#1a2035</Color>
    
    <!-- Text Colors -->
    <Color x:Key="TextPrimary">#F0F4FF</Color>
    <Color x:Key="TextSecondary">#7a8aa8</Color>
    <Color x:Key="TextMuted">#4a5568</Color>

    <!-- Brand / Accent Colors - New Palette -->
    <Color x:Key="PrimaryAccent">#10d9a0</Color>   <!-- Emerald - Income -->
    <Color x:Key="VioletAccent">#7c6df8</Color>    <!-- Violet - Accent -->
    <Color x:Key="RoseAccent">#f43f5e</Color>      <!-- Rose - Expense -->
    <Color x:Key="AmberAccent">#f59e0b</Color>     <!-- Amber - Warning -->
    <Color x:Key="ChartBlue">#3b82f6</Color>
    <Color x:Key="ChartPurple">#7c6df8</Color>
    <Color x:Key="ChartTeal">#10d9a0</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#10d9a0</Color>
    <Color x:Key="DangerColor">#f43f5e</Color>
    <Color x:Key="WarningColor">#f59e0b</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackground}" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="{StaticResource SidebarBackground}" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{StaticResource CardBackground}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="SidebarTextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="SidebarTextSecondaryBrush" Color="{StaticResource TextSecondary}" />

    <SolidColorBrush x:Key="PrimaryAccentBrush" Color="{StaticResource PrimaryAccent}" />
    <SolidColorBrush x:Key="VioletAccentBrush" Color="{StaticResource VioletAccent}" />
    <SolidColorBrush x:Key="RoseAccentBrush" Color="{StaticResource RoseAccent}" />
    <SolidColorBrush x:Key="AmberAccentBrush" Color="{StaticResource AmberAccent}" />
    <SolidColorBrush x:Key="ChartTealBrush" Color="{StaticResource PrimaryAccent}" />
    <SolidColorBrush x:Key="ChartBlueBrush" Color="{StaticResource ChartBlue}" />
    <SolidColorBrush x:Key="ChartPurpleBrush" Color="{StaticResource ChartPurple}" />
    <SolidColorBrush x:Key="ChartYellowBrush" Color="{StaticResource AmberAccent}" />
    
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    
    <!-- Translucent Backgrounds -->
    <SolidColorBrush x:Key="CardPastelOrangeBrush" Color="#20f59e0b" />
    <SolidColorBrush x:Key="CardPastelGreenBrush" Color="#2010d9a0" />
    <SolidColorBrush x:Key="CardPastelPurpleBrush" Color="#207c6df8" />
    <SolidColorBrush x:Key="CardPastelBlueBrush" Color="#203b82f6" />
    <SolidColorBrush x:Key="CardPastelRoseBrush" Color="#20f43f5e" />

    <SolidColorBrush x:Key="TranslucentPrimaryBrush" Color="#3510d9a0" />
    <SolidColorBrush x:Key="TranslucentVioletBrush" Color="#357c6df8" />
    <SolidColorBrush x:Key="TranslucentRoseBrush" Color="#35f43f5e" />
    <SolidColorBrush x:Key="TranslucentBlueBrush" Color="#353b82f6" />
    
    <SolidColorBrush x:Key="ActiveSidebarButtonBrush" Color="#1510d9a0" />
    <SolidColorBrush x:Key="HoverSidebarProfileBrush" Color="#207c6df8" />
    
    <SolidColorBrush x:Key="ListHoverBrush" Color="#0d111a" />
    <SolidColorBrush x:Key="IconBorderBrush" Color="#40ffffff" />
    <SolidColorBrush x:Key="IconBackgroundBrush" Color="#2b3147" />
    <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#15ffffff" />

</ResourceDictionary>
