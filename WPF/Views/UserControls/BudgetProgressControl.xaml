<UserControl x:Class="WPF.Views.UserControls.BudgetProgressControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,18">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Category name + amounts -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource IconBackgroundBrush}" Margin="0,0,10,0" BorderBrush="{DynamicResource IconBorderBrush}" BorderThickness="1">
                    <TextBlock Text="{Binding Icon}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                </Border>
                <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{Binding FormattedSpent}" Foreground="{Binding ProgressBrush}"
                           FontSize="13" FontWeight="Bold" FontFamily="Segoe UI"/>
                <TextBlock Text=" / " Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                <TextBlock Text="{Binding FormattedTotal}" Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Progress bar using ProgressBar control (AnimatedProgress 0-100) -->
        <ProgressBar Grid.Row="1" Height="6" Minimum="0" Maximum="100"
                     Value="{Binding AnimatedProgress, Mode=OneWay}"
                     Foreground="{Binding ProgressBrush}"
                     Background="{DynamicResource CardBorderBrush}" BorderThickness="0"
                     Style="{StaticResource ModernProgressBar}"/>

        <!-- Status text + percentage -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                       Foreground="{Binding ProgressBrush}"
                       HorizontalAlignment="Left"/>
            <TextBlock HorizontalAlignment="Right" FontSize="11" Foreground="{Binding ProgressBrush}" FontWeight="SemiBold">
                <Run Text="{Binding ProgressPercentage, Mode=OneWay, StringFormat={}{0:0}}"/>
                <Run Text="%"/>
            </TextBlock>
        </Grid>
    </Grid>
</UserControl>
