<UserControl x:Class="WPF.Views.UserControls.TransactionsViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Views.UserControls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Range button style -->
        <Style x:Key="RangeBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="#7a8aa8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252C3D"/>
                                <Setter Property="Foreground" Value="#F0F4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Active range button -->
        <Style x:Key="RangeBtnActive" TargetType="Button" BasedOn="{StaticResource RangeBtn}">
            <Setter Property="Background" Value="{DynamicResource ActiveSidebarButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Type toggle button -->
        <Style x:Key="TypeBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="#7a8aa8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252C3D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TypeBtnActive" TargetType="Button" BasedOn="{StaticResource TypeBtn}">
            <Setter Property="Background" Value="#2510d9a0"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Category pill -->
        <Style x:Key="PillBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="{Binding PillBackground}"/>
            <Setter Property="Foreground" Value="{Binding PillForeground}"/>
            <Setter Property="Command" Value="{Binding ToggleCommand}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="{TemplateBinding Foreground}" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Page button -->
        <Style x:Key="PageBtn" TargetType="Button" BasedOn="{StaticResource RangeBtn}">
            <Setter Property="Padding" Value="16,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- TextBox transparent -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F0F4FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource FadeInSlideUpAnimation}"/>
            </EventTrigger>
        </Grid.Triggers>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Detail panel -->
            <ColumnDefinition Width="{Binding DetailPanelWidth}"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════ MAIN COLUMN ══════════════════ -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>

                <!-- ── Removed Page Header ── -->

                <!-- ── 3 Stat Mini Cards ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}"
                            BorderBrush="{DynamicResource VioletAccentBrush}" BorderThickness="0,0,0,3"
                            CornerRadius="12" Padding="18" Margin="0,0,10,0" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding CardTotal.Label}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CardTotal.FormattedValue}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40"
                                    CornerRadius="10" Background="{DynamicResource TranslucentVioletBrush}">
                                <TextBlock Text="{Binding CardTotal.Icon}" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Income -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12" Padding="18" Margin="10,0,10,0"
                            BorderBrush="{DynamicResource PrimaryAccentBrush}" BorderThickness="0,0,0,3" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding CardIncome.Label}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CardIncome.FormattedValue}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40"
                                    CornerRadius="10" Background="{DynamicResource TranslucentPrimaryBrush}">
                                <TextBlock Text="{Binding CardIncome.Icon}" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Expense -->
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}"
                            CornerRadius="12" Padding="18" Margin="10,0,0,0"
                            BorderBrush="{DynamicResource RoseAccentBrush}" BorderThickness="0,0,0,3" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding CardExpense.Label}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding CardExpense.FormattedValue}" FontSize="28" FontWeight="Bold"
                                           Foreground="{DynamicResource RoseAccentBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40"
                                    CornerRadius="10" Background="{DynamicResource TranslucentRoseBrush}">
                                <TextBlock Text="{Binding CardExpense.Icon}" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Bar Chart + Range ── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Biểu đồ thu chi theo ngày" FontWeight="Bold" FontSize="15"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Thu nhập vs Chi tiêu" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,3,0,0"/>
                            </StackPanel>
                            <!-- Range buttons -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="7 ngày" Style="{StaticResource RangeBtn}"
                                        Command="{Binding SetRange7Command}" Margin="0,0,6,0"/>
                                <Button Content="30 ngày" Style="{StaticResource RangeBtnActive}"
                                        Command="{Binding SetRange30Command}" Margin="0,0,6,0"/>
                                <Button Content="3 tháng" Style="{StaticResource RangeBtn}"
                                        Command="{Binding SetRange90Command}"/>
                            </StackPanel>
                        </Grid>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ChartSeries}"
                                            XAxes="{Binding ChartXAxes}" YAxes="{Binding ChartYAxes}"
                                            TooltipPosition="Top" AnimationsSpeed="00:00:00.5"
                                            LegendPosition="Right"
                                            LegendTextPaint="{Binding ChartLegendTextPaint}"/>
                    </Grid>
                </Border>

                <!-- ── Filters Row ── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Search + Type Toggle + Export -->
                        <Grid Margin="0,0,0,14">
                            <!-- Search box -->
                            <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="1" CornerRadius="10" Padding="14,8"
                                    HorizontalAlignment="Left" Width="300">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔍 " Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" FontSize="14"/>
                                    <TextBox Style="{StaticResource SearchBox}" Width="240"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalAlignment="Center">
                                        <TextBox.Resources>
                                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="0"/></Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                            </Border>

                            <!-- Right side: Type toggle + Export -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}"
                                        BorderThickness="1" CornerRadius="20" Padding="4" Margin="0,0,12,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Tất cả" Command="{Binding SetAllCommand}"
                                                Style="{StaticResource TypeBtnActive}"/>
                                        <Button Content="Thu nhập" Command="{Binding SetIncomeCommand}"
                                                Style="{StaticResource TypeBtn}"/>
                                        <Button Content="Chi tiêu" Command="{Binding SetExpenseCommand}"
                                                Style="{StaticResource TypeBtn}"/>
                                    </StackPanel>
                                </Border>
                                <Button Content="⬇ Xuất CSV" Command="{Binding ExportCsvCommand}"
                                        Style="{StaticResource RangeBtn}" Padding="14,7"/>
                            </StackPanel>
                        </Grid>

                        <!-- Category Pills -->
                        <ItemsControl ItemsSource="{Binding CategoryPills}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource PillBtn}"
                                            Background="{Binding PillBackground}"
                                            Foreground="{Binding PillForeground}"
                                            Command="{Binding ToggleCommand}"
                                            Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Icon}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Name}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ── Transaction List Grouped by Date ── -->
                <ItemsControl ItemsSource="{Binding GroupedList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Date Group -->
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Group header -->
                                    <Grid Margin="0,0,0,14">
                                        <Border Background="{DynamicResource CardBorderBrush}" CornerRadius="8" Padding="10,4" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding DateLabel}" FontSize="13" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="{Binding DayTotal}" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center" FontSize="14" FontWeight="Bold"
                                                   Foreground="{Binding TotalBrush}"/>
                                    </Grid>

                                    <!-- Transactions in group -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" CornerRadius="10" Padding="6,8" Margin="0,0,0,4" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding Gesture="LeftClick"
                                                                      Command="{Binding DataContext.SelectTransactionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#08FFFFFF"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                                                                Background="{Binding IconBackground}" Margin="0,0,14,0">
                                                            <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" FontSize="20"/>
                                                        </Border>

                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                                <Border Background="{DynamicResource ActiveSidebarButtonBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                                    <TextBlock Text="{Binding Category}" FontSize="11"
                                                                               Foreground="{DynamicResource PrimaryAccentBrush}"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding FormattedDate}" FontSize="11"
                                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <TextBlock Grid.Column="2" Text="{Binding FormattedAmount}"
                                                                   FontWeight="Bold" FontSize="15"
                                                                   Foreground="{Binding AmountColorBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ── Pagination ── -->
                <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1" CornerRadius="12" Padding="16,12" Margin="0,4,0,20">
                    <Grid>
                        <Button Content="← Trước" Style="{StaticResource PageBtn}"
                                Command="{Binding PrevPageCommand}" HorizontalAlignment="Left"/>
                        <TextBlock Text="{Binding PageLabel}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <Button Content="Sau →" Style="{StaticResource PageBtn}"
                                Command="{Binding NextPageCommand}" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ══════════════════ DETAIL PANEL ══════════════════ -->
        <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding IsDetailOpen, Converter={StaticResource BoolToVis}}"
                Padding="20">
            <Border.RenderTransform>
                <TranslateTransform X="0"/>
            </Border.RenderTransform>
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.X"
                                             From="50" To="0" Duration="0:0:0.25">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <ScrollViewer VerticalScrollBarVisibility="Hidden">
                <StackPanel DataContext="{Binding SelectedTransaction}">
                    <!-- Header -->
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Chi tiết giao dịch" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Content="✕" HorizontalAlignment="Right" Background="Transparent"
                                BorderThickness="0" Foreground="{DynamicResource TextSecondaryBrush}"
                                FontSize="16" Cursor="Hand"
                                Command="{Binding DataContext.CloseDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </Grid>

                    <!-- Big icon + title -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,24">
                        <Border Width="72" Height="72" CornerRadius="20" Background="{Binding IconBackground}"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <TextBlock Text="{Binding Icon}" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextAlignment="Center"/>
                        <TextBlock Text="{Binding Category}" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Big amount -->
                    <TextBlock Text="{Binding FormattedAmount}" FontSize="32" FontWeight="Bold"
                               Foreground="{Binding AmountColorBrush}" TextAlignment="Center" Margin="0,0,0,24"/>

                    <!-- Detail rows -->
                    <Border Background="{DynamicResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Ngày" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding Date, StringFormat={}{0:dd/MM/yyyy HH:mm}}"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                           HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Separator Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,10">
                                <TextBlock Text="Danh mục" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontSize="13" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                            </Grid>
                            <Separator Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,10"/>
                            <Grid>
                                <TextBlock Text="Loại" Foreground="{DynamicResource TextMutedBrush}" FontSize="13"/>
                                <TextBlock Foreground="{Binding AmountColorBrush}" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Right">
                                    <TextBlock.Text>
                                        <Binding Path="IsExpense">
                                            <Binding.Converter>
                                                <BooleanToVisibilityConverter/>
                                            </Binding.Converter>
                                        </Binding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Action buttons -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="✏️ Sửa" Margin="0,0,6,0" Padding="0,10"
                                Background="{DynamicResource CardBorderBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                BorderThickness="0" FontSize="13" Cursor="Hand"
                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                            </Button.Resources>
                        </Button>
                        <Button Grid.Column="1" Content="🗑️ Xóa" Margin="6,0,0,0" Padding="0,10"
                                Background="{DynamicResource CardPastelRoseBrush}" Foreground="{DynamicResource RoseAccentBrush}"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding SelectedTransaction, RelativeSource={RelativeSource AncestorType=UserControl}}">
                            <Button.Resources>
                                <Style TargetType="Border"><Setter Property="CornerRadius" Value="10"/></Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
