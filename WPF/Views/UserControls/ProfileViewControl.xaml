<UserControl x:Class="WPF.Views.UserControls.ProfileViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0" Padding="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource FadeInSlideUpAnimation}"/>
            </EventTrigger>
        </Grid.Triggers>
        <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- Left: Avatar & Info -->
                        <ColumnDefinition Width="3*"/>
                        <!-- Right: Settings & Password -->
                        <ColumnDefinition Width="5*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ── Left Profile Card ── -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" VerticalAlignment="Top" Margin="0,0,20,0">
                        <StackPanel>
                            <!-- Avatar -->
                            <Border Width="100" Height="100" CornerRadius="50" Background="{DynamicResource ChartPurpleBrush}" Margin="0,10,0,20" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding AvatarInitials}" Foreground="White" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Basic Info -->
                            <TextBlock Text="{Binding FullName}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Email}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                            <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,0,0,20"/>

                            <!-- Plan Info -->
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource CardPastelOrangeBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="⭐" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Gói tài khoản" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding SubscriptionPlan}" Foreground="{DynamicResource AmberAccentBrush}" FontSize="15" FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource CardPastelGreenBrush}" Margin="0,0,12,0">
                                    <TextBlock Text="☁️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Dung lượng dữ liệu" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                                    <TextBlock Text="{Binding TotalDataSize}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="{Binding JoinDate}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,20,0,0" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Right Setting Cards ── -->
                    <StackPanel Grid.Column="1">
                        
                        <!-- Personal Info -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Thông tin cá nhân" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <StackPanel Grid.Column="0" Margin="0,0,10,15">
                                        <TextBlock Text="Họ và tên" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding FullName, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,15">
                                        <TextBlock Text="Số điện thoại" Style="{StaticResource InputLabel}"/>
                                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Email" Style="{StaticResource InputLabel}"/>
                                    <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Foreground="{DynamicResource TextMutedBrush}"/>
                                </StackPanel>

                                <Button Content="Cập nhật thông tin" Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource AppBackgroundBrush}"
                                        FontWeight="Bold" Padding="20,12" HorizontalAlignment="Right" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Change Password -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Đổi mật khẩu" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                                
                                <!-- Alert Box -->
                                <Border Margin="0,0,0,15" Padding="12" CornerRadius="6" Visibility="{Binding HasAlert, Converter={StaticResource BoolToVis}}">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CardPastelGreenBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlertError}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource CardPastelRoseBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource RoseAccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding AlertMessage}" TextWrapping="Wrap" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAlertError}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource RoseAccentBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="OldPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock Text="Mật khẩu mới" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="NewPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource InputLabel}"/>
                                    <PasswordBox PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>
                                </StackPanel>

                                <Button Content="Lưu mật khẩu mới" Command="{Binding ChangePasswordCommand}" 
                                        Background="{DynamicResource CardBorderBrush}" Foreground="{DynamicResource TextPrimaryBrush}"
                                        FontWeight="Bold" Padding="20,12" HorizontalAlignment="Right" BorderThickness="0" Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#252C3D"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
