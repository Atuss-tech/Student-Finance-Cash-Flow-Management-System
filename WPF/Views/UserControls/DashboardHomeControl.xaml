<UserControl x:Class="WPF.Views.UserControls.DashboardHomeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Views.UserControls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
        <Grid Margin="0,0,0,20">
            <Grid.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard Storyboard="{StaticResource FadeInSlideUpAnimation}"/>
                </EventTrigger>
            </Grid.Triggers>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ========== ROW 0: Stat Cards ========== -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <uc:SummaryCardControl Grid.Column="0" Margin="0,0,10,0" DataContext="{Binding TotalBalance}"/>
                <uc:SummaryCardControl Grid.Column="1" Margin="10,0,10,0" DataContext="{Binding TotalIncome}"/>
                <uc:SummaryCardControl Grid.Column="2" Margin="10,0,10,0" DataContext="{Binding TotalExpense}"/>
                <uc:SummaryCardControl Grid.Column="3" Margin="10,0,0,0" DataContext="{Binding NetCashFlow}"/>
            </Grid>

            <!-- ========== ROW 1: Charts ========== -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Area Chart Card -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="280"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Dòng tiền 12 tháng" FontWeight="Bold" FontSize="16"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <!-- Live pulse dot -->
                                    <Ellipse x:Name="PulseDot" Width="8" Height="8" Fill="{DynamicResource PrimaryAccentBrush}"
                                             VerticalAlignment="Center" Margin="0,0,6,0">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard Storyboard="{StaticResource PulseAnimation}"/>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <TextBlock Text="Cập nhật theo thời gian thực" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                            <!-- Legend -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource PrimaryAccentBrush}" Margin="0,0,5,0"/>
                                <TextBlock Text="Thu nhập" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,16,0"/>
                                <Ellipse Width="8" Height="8" Fill="{DynamicResource RoseAccentBrush}" Margin="0,0,5,0"/>
                                <TextBlock Text="Chi tiêu" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Grid>

                        <lvc:CartesianChart Grid.Row="1" Series="{Binding ChartSeries}"
                                            XAxes="{Binding XAxes}" YAxes="{Binding YAxes}"
                                            TooltipPosition="Top" AnimationsSpeed="00:00:00.4"/>
                    </Grid>
                </Border>

                <!-- Donut Chart Card -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="280"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Phân bổ chi tiêu" FontWeight="Bold" FontSize="16"
                                       Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                            <TextBlock Text="Tháng 7/2025" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <lvc:PieChart Grid.Row="1" Series="{Binding ExpenseAllocationSeries}"
                                      LegendPosition="Bottom" AnimationsSpeed="00:00:01.0"
                                      LegendTextPaint="{Binding ChartLegendTextPaint}"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- ========== ROW 2: Transactions + Budgets ========== -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Transactions -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Giao dịch gần đây" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="8 giao dịch mới nhất" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Content="Xem tất cả →" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{DynamicResource PrimaryAccentBrush}"
                                    Command="{Binding ShowTransactionsCommand}" Cursor="Hand"
                                    FontWeight="SemiBold" FontSize="13"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" MaxHeight="380">
                            <ItemsControl ItemsSource="{Binding RecentTransactions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <uc:RecentTransactionControl/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Budget Progress -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="Ngân sách tháng" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="Segoe UI"/>
                                <TextBlock Text="5 danh mục • Tháng 7/2025" FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Width="28" Height="28" Background="{DynamicResource CardBorderBrush}"
                                    CornerRadius="14" Cursor="Hand">
                                <TextBlock Text="+" Foreground="{DynamicResource PrimaryAccentBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontWeight="Bold" FontSize="16"/>
                            </Border>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                            <ItemsControl ItemsSource="{Binding BudgetProgresses}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <uc:BudgetProgressControl/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
