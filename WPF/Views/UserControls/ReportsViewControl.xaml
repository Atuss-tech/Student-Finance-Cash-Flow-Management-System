<UserControl x:Class="WPF.Views.UserControls.ReportsViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:uc="clr-namespace:WPF.Views.UserControls"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Range button style -->
        <Style x:Key="RangeBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Foreground" Value="#7a8aa8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252C3D"/>
                                <Setter Property="Foreground" Value="#F0F4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard Storyboard="{StaticResource FadeInSlideUpAnimation}"/>
            </EventTrigger>
        </Grid.Triggers>
        <ScrollViewer VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly" Margin="0,0,10,0">
            <StackPanel>
                
                <!-- ── Time Filters Row ── -->
                <Grid Margin="0,0,0,20">
                    <!-- Time Filters -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Thời gian: " Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Button Content="30 ngày" Style="{StaticResource RangeBtn}" Command="{Binding SetRange30Command}"/>
                        <Button Content="3 tháng" Style="{StaticResource RangeBtn}" Command="{Binding SetRange90Command}"/>
                        <Button Content="6 tháng" Style="{StaticResource RangeBtn}" Command="{Binding SetRange180Command}" Margin="0"/>
                    </StackPanel>
                </Grid>

                <!-- ── 3 Stat Mini Cards ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource PrimaryAccentBrush}" BorderThickness="0,0,0,3" CornerRadius="12" Padding="18" Margin="0,0,10,0" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TotalIncomeReport.Title}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalIncomeReport.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding TotalIncomeReport.Subtext}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40" CornerRadius="10" Background="{DynamicResource TranslucentPrimaryBrush}">
                                <TextBlock Text="{Binding TotalIncomeReport.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource RoseAccentBrush}" BorderThickness="0,0,0,3" CornerRadius="12" Padding="18" Margin="5,0,5,0" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding TotalExpenseReport.Title}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding TotalExpenseReport.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource RoseAccentBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding TotalExpenseReport.Subtext}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40" CornerRadius="10" Background="{DynamicResource TranslucentRoseBrush}">
                                <TextBlock Text="{Binding TotalExpenseReport.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                    
                    <Border Grid.Column="2" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource VioletAccentBrush}" BorderThickness="0,0,0,3" CornerRadius="12" Padding="18" Margin="10,0,0,0" Style="{StaticResource HoverBorderStyle}">
                        <Grid>
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="{Binding NetCashFlowReport.Title}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding NetCashFlowReport.FormattedValue}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource VioletAccentBrush}" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding NetCashFlowReport.Subtext}" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Border HorizontalAlignment="Right" VerticalAlignment="Center" Width="40" Height="40" CornerRadius="10" Background="{DynamicResource TranslucentVioletBrush}">
                                <TextBlock Text="{Binding NetCashFlowReport.Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Charts Row ── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="6*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Donut: Expense Allocation -->
                    <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Tỷ trọng chi tiêu" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Nhấn vào biểu đồ để xem chi tiết" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,10"/>
                            </StackPanel>
                            <lvc:PieChart Grid.Row="1" Series="{Binding ExpenseAllocationSeries}" AnimationsSpeed="00:00:01.0"
                                          LegendPosition="Bottom" LegendTextPaint="{Binding ChartLegendTextPaint}" Height="280"
                                          TooltipPosition="Top"/>
                        </Grid>
                    </Border>

                    <!-- Bar Chart: Cash Flow Trend -->
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Xu hướng dòng tiền" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="So sánh Tổng thu vs Tổng chi" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,10"/>
                            </StackPanel>
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding CashFlowTrendSeries}" XAxes="{Binding CashFlowXAxes}" YAxes="{Binding CashFlowYAxes}"
                                                TooltipPosition="Top" AnimationsSpeed="00:00:00.5" LegendPosition="Bottom" LegendTextPaint="{Binding ChartLegendTextPaint}" Height="280"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ── Drill Down: Detailed Transactions ── -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <TextBlock Text="{Binding SelectedCategoryLabel}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Không có giao dịch nào thỏa mãn bộ lọc." Foreground="{DynamicResource TextMutedBrush}" 
                                       FontStyle="Italic" HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Visibility="{Binding HasData, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
                        </Grid>

                        <Border Grid.Row="1" Background="{DynamicResource CardBorderBrush}" CornerRadius="6" Padding="15,10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Giao dịch" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Danh mục" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Thời gian" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3" Text="Số tiền" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                            </Grid>
                        </Border>

                        <ItemsControl Grid.Row="2" ItemsSource="{Binding DetailTransactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="10,12" Background="Transparent">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Title -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <Border Width="30" Height="30" CornerRadius="6" Background="{DynamicResource IconBackgroundBrush}" Margin="0,0,10,0" BorderBrush="{DynamicResource IconBorderBrush}" BorderThickness="1">
                                                    <TextBlock Text="{Binding Icon}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                </Border>
                                                <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            </StackPanel>
                                            
                                            <!-- Category Badge -->
                                            <Border Grid.Column="1" Background="{DynamicResource HoverSidebarProfileBrush}" CornerRadius="4" Padding="6,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Category}" Foreground="{DynamicResource VioletAccentBrush}" FontSize="11"/>
                                            </Border>
                                            
                                            <!-- Date -->
                                            <TextBlock Grid.Column="2" Text="{Binding FormattedDate}" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" FontSize="13"/>
                                            
                                            <!-- Amount -->
                                            <TextBlock Grid.Column="3" Text="{Binding FormattedAmount}" Foreground="{Binding AmountColorBrush}" 
                                                       FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
