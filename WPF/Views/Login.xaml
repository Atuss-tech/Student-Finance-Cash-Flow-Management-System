<Window x:Class="Student_Finance___Cash_Flow_Management_System.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Finance - Welcome" Height="650" Width="1100" WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseLeftButtonDown="Window_MouseDown">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ProgressBarFill" Storyboard.TargetProperty="Width" From="0" To="120" Duration="0:0:1.5">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="BarT1" Storyboard.TargetProperty="Height" From="0" To="60" Duration="0:0:1" BeginTime="0:0:0.1">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BarT2" Storyboard.TargetProperty="Height" From="0" To="70" Duration="0:0:1" BeginTime="0:0:0.2">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BarT3" Storyboard.TargetProperty="Height" From="0" To="50" Duration="0:0:1" BeginTime="0:0:0.3">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BarT4" Storyboard.TargetProperty="Height" From="0" To="80" Duration="0:0:1" BeginTime="0:0:0.4">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BarT5" Storyboard.TargetProperty="Height" From="0" To="75" Duration="0:0:1" BeginTime="0:0:0.5">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BarT6" Storyboard.TargetProperty="Height" From="0" To="100" Duration="0:0:1" BeginTime="0:0:0.6">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>

                    <DoubleAnimation Storyboard.TargetName="DonutChartRotation" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1.5">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="DonutChart" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.5"/>

                    <DoubleAnimation Storyboard.TargetName="LineChartTranslation" Storyboard.TargetProperty="Y" From="50" To="0" Duration="0:0:1.5">
                        <DoubleAnimation.EasingFunction><CircleEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="LineChart" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1.5"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Border CornerRadius="20" Background="#F8F8FD">
        <Border.Effect>
            <DropShadowEffect BlurRadius="25" ShadowDepth="10" Opacity="0.15" Color="#000000"/>
        </Border.Effect>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Close Button -->
            <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="15" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnClose_Click" Panel.ZIndex="10">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <TextBlock Text="✕" FontSize="18" Foreground="#8F92A1" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Left Form Area -->
            <Grid Grid.Column="0" Margin="60,40,40,40">
                <TabControl x:Name="MainTabControl" Background="Transparent" BorderThickness="0" SelectionChanged="MainTabControl_SelectionChanged">
                    <!-- Hide Tab Headers -->
                    <TabControl.ItemContainerStyle>
                        <Style TargetType="TabItem">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </Style>
                    </TabControl.ItemContainerStyle>
                    
                    <TabItem x:Name="TabLogin">
                        <StackPanel VerticalAlignment="Center">

                            <TextBlock FontSize="42" FontWeight="Heavy" Foreground="#1A1D2D" Margin="0,0,0,8">
                                Chào mừng trở lại<Run Foreground="#6C5DD3">.</Run>
                            </TextBlock>
                            <TextBlock FontSize="15" Foreground="#8F92A1" Margin="0,0,0,35">
                                Chưa có tài khoản? <Hyperlink Foreground="#6C5DD3" TextDecorations="None" FontWeight="Bold" Click="GoToRegister_Click">Đăng ký miễn phí</Hyperlink>
                            </TextBlock>

                            <TextBlock Text="Email" Foreground="#1A1D2D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F7F9" CornerRadius="12" Margin="0,0,0,25">
                                <TextBox x:Name="txtLoginEmail" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch"/>
                            </Border>

                            <TextBlock Text="Mật khẩu" Foreground="#1A1D2D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F7F9" CornerRadius="12" Margin="0,0,0,25">
                                <Grid>
                                    <PasswordBox x:Name="txtLoginPassword" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch" Margin="0,0,40,0"/>
                                    <TextBox x:Name="txtLoginPasswordVisible" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch" Margin="0,0,40,0"/>
                                    
                                    <!-- Simple eye icon with animation -->
                                    <Button x:Name="btnToggleLoginPassword" Click="btnToggleLoginPassword_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Grid Width="20" Height="20" RenderTransformOrigin="0.5,0.5">
                                            <Grid.RenderTransform>
                                                <ScaleTransform x:Name="LoginEyeScale" ScaleY="1"/>
                                            </Grid.RenderTransform>
                                            <Path Data="M 10,4 C 4,4 0,10 0,10 C 0,10 4,16 10,16 C 16,16 20,10 20,10 C 20,10 16,4 10,4 Z M 10,14 C 7.8,14 6,12.2 6,10 C 6,7.8 7.8,6 10,6 C 12.2,6 14,7.8 14,10 C 14,12.2 12.2,14 10,14 Z M 10,8 C 8.9,8 8,8.9 8,10 C 8,11.1 8.9,12 10,12 C 11.1,12 12,11.1 12,10 C 12,8.9 11.1,8 10,8 Z" Fill="#A0A0B0" Stretch="Uniform"/>
                                            <Path x:Name="LoginEyeSlash" Data="M 2,2 L 18,18" Stroke="#A0A0B0" StrokeThickness="2" StrokeDashArray="25" StrokeDashOffset="0" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>

                            <Grid Margin="0,0,0,35">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Content="Ghi nhớ đăng nhập" Foreground="#8F92A1" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="Quên mật khẩu?" Foreground="#6C5DD3" FontWeight="Bold" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"/>
                            </Grid>

                            <Grid>
                                <Button x:Name="btnLogin" Content="Đăng nhập" Click="btnLogin_Click" HorizontalAlignment="Stretch" Height="55" Background="#6C5DD3" Foreground="White" FontSize="16" FontWeight="Bold" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Bottom Tags -->
                        
                        </StackPanel>
                    </TabItem>

                    <TabItem x:Name="TabRegister">
                        <StackPanel VerticalAlignment="Center">
                     
                            
                            <TextBlock FontSize="42" FontWeight="Heavy" Foreground="#1A1D2D" Margin="0,0,0,8">
                                Đăng ký miễn phí<Run Foreground="#6C5DD3">.</Run>
                            </TextBlock>
                            <TextBlock FontSize="15" Foreground="#8F92A1" Margin="0,0,0,35">
                                Đã có tài khoản? <Hyperlink Foreground="#6C5DD3" TextDecorations="None" FontWeight="Bold" Click="GoToLogin_Click">Đăng nhập ngay</Hyperlink>
                            </TextBlock>

                            <TextBlock Text="Họ và Tên" Foreground="#1A1D2D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F7F9" CornerRadius="12" Margin="0,0,0,20">
                                <TextBox x:Name="txtRegisterFullName" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch"/>
                            </Border>

                            <TextBlock Text="Email" Foreground="#1A1D2D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F7F9" CornerRadius="12" Margin="0,0,0,20">
                                <TextBox x:Name="txtRegisterEmail" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch"/>
                            </Border>

                            <TextBlock Text="Mật khẩu" Foreground="#1A1D2D" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#F7F7F9" CornerRadius="12" Margin="0,0,0,30">
                                <Grid>
                                    <PasswordBox x:Name="txtRegisterPassword" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch" Margin="0,0,40,0"/>
                                    <TextBox x:Name="txtRegisterPasswordVisible" Visibility="Collapsed" Background="Transparent" BorderThickness="0" Padding="15,14" FontSize="15" Foreground="#1A1D2D" HorizontalAlignment="Stretch" Margin="0,0,40,0"/>
                                    
                                    <Button x:Name="btnToggleRegisterPassword" Click="btnToggleRegisterPassword_Click" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                        <Grid Width="20" Height="20" RenderTransformOrigin="0.5,0.5">
                                            <Grid.RenderTransform>
                                                <ScaleTransform x:Name="RegisterEyeScale" ScaleY="1"/>
                                            </Grid.RenderTransform>
                                            <Path Data="M 10,4 C 4,4 0,10 0,10 C 0,10 4,16 10,16 C 16,16 20,10 20,10 C 20,10 16,4 10,4 Z M 10,14 C 7.8,14 6,12.2 6,10 C 6,7.8 7.8,6 10,6 C 12.2,6 14,7.8 14,10 C 14,12.2 12.2,14 10,14 Z M 10,8 C 8.9,8 8,8.9 8,10 C 8,11.1 8.9,12 10,12 C 11.1,12 12,11.1 12,10 C 12,8.9 11.1,8 10,8 Z" Fill="#A0A0B0" Stretch="Uniform"/>
                                            <Path x:Name="RegisterEyeSlash" Data="M 2,2 L 18,18" Stroke="#A0A0B0" StrokeThickness="2" StrokeDashArray="25" StrokeDashOffset="0" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                        </Grid>
                                    </Button>
                                </Grid>
                            </Border>

                            <Button x:Name="btnRegister" Content="Tạo tài khoản" Click="btnRegister_Click" Height="55" Background="#6C5DD3" Foreground="White" FontSize="16" FontWeight="Bold" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>

            <!-- Right Side Dashboard Preview -->
            <Grid Grid.Column="1" Margin="15,25,25,25" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Top Card: Số dư khả dụng -->
                <Border Grid.Row="0" CornerRadius="15" Padding="25,20,25,20" Margin="0,0,0,15">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6C5DD3" Offset="0"/>
                            <GradientStop Color="#4e54c8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0">
                            <StackPanel>
                                <TextBlock Text="Số dư khả dụng" Foreground="#E0DDFB" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="2.450.000đ" Foreground="White" FontSize="32" FontWeight="Bold"/>
                            </StackPanel>
                            <!-- % Tag -->
                            <Border Background="#40FFFFFF" CornerRadius="15" Padding="12,5" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <TextBlock Text="↗ +8.3%" Foreground="White" FontSize="12" FontWeight="Bold"/>
                            </Border>
                        </Grid>

                        <!-- Line Chart Mock -->
                        <Grid x:Name="LineChart" Grid.Row="1" Margin="0,15,0,0">
                            <Grid.RenderTransform>
                                <TranslateTransform x:Name="LineChartTranslation" Y="0"/>
                            </Grid.RenderTransform>
                            <Path Stroke="White" StrokeThickness="2" Data="M 0,45 L 40,40 L 90,42 L 140,25 L 190,30 L 250,15 L 300,10 L 330,12" Stretch="Fill" VerticalAlignment="Center"/>
                            <Ellipse Width="6" Height="6" Fill="White" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,30,0"/>
                        </Grid>

                        <!-- Footer -->
                        <Grid Grid.Row="2" Margin="0,15,0,0">
                            <TextBlock Text="6 tháng gần nhất" Foreground="#C8C2F5" FontSize="12"/>
                            <TextBlock Text="↑ Tăng trưởng tốt" Foreground="White" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Middle Cards: Tiết kiệm & Chi tiêu -->
                <Grid Grid.Row="1" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Tiết kiệm Card -->
                    <Border Grid.Column="0" Background="White" CornerRadius="15" Padding="20" Margin="0,0,10,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Tiết kiệm" Foreground="#8F92A1" FontSize="14" FontWeight="SemiBold"/>
                            <TextBlock Grid.Row="1" Text="680.000đ" Foreground="#1A1D2D" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                            <TextBlock Grid.Row="1" Text="↗ +12.4%" Foreground="#2ECC71" FontSize="13" FontWeight="Bold" Margin="0,35,0,0"/>
                            
                            <!-- Progress Bar -->
                            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                                <Grid Height="8">
                                    <Border Background="#F0F0F5" CornerRadius="4"/>
                                    <Border x:Name="ProgressBarFill" Background="#4BC9F6" CornerRadius="4" Width="0" HorizontalAlignment="Left"/>
                                </Grid>
                                <TextBlock Text="Mục tiêu: 1.100.000đ" Foreground="#A0A0B0" FontSize="12" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Chi tiêu Card -->
                    <Border Grid.Column="1" Background="White" CornerRadius="15" Padding="20" Margin="5,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.05" Color="Black"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Chi tiêu" Foreground="#8F92A1" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                            <!-- Donut Chart Mock -->
                            <Grid x:Name="DonutChart" Width="70" Height="70" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <RotateTransform x:Name="DonutChartRotation" Angle="0"/>
                                </Grid.RenderTransform>
                                <Path Fill="#FF9F43" Data="M 35,0 A 35,35 0 0,1 70,35 L 55,35 A 20,20 0 0,0 35,15 Z"/>
                                <Path Fill="#6C5DD3" Data="M 70,35 A 35,35 0 0,1 35,70 L 35,55 A 20,20 0 0,0 55,35 Z"/>
                                <Path Fill="#2ECC71" Data="M 35,70 A 35,35 0 0,1 0,35 L 15,35 A 20,20 0 0,0 35,55 Z"/>
                                <Path Fill="#EA5455" Data="M 0,35 A 35,35 0 0,1 35,0 L 35,15 A 20,20 0 0,0 15,35 Z"/>
                                <!-- The text should not rotate so we keep it outside the rotation if we want, or just let it rotate (the user will see 100% spin) -->
                                <!-- Wait, to keep text straight, we can rotate the paths only, but spinning text looks cool anyway. I'll just keep it here. -->
                                <TextBlock Text="100%" FontSize="14" FontWeight="Bold" Foreground="#1A1D2D" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="DonutTextCounterRotation" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Bottom Card: Chi tiêu theo tháng -->
                <Border Grid.Row="2" Background="White" CornerRadius="15" Padding="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.05" Color="Black"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header & Stock tags -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Chi tiêu&#x0a;theo tháng" Foreground="#8F92A1" FontSize="13" FontWeight="SemiBold" LineHeight="18" Margin="0,0,15,0"/>
                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="VNM " Foreground="#1A1D2D" FontSize="11" FontWeight="Bold"/><TextBlock Text=" ↗ +1.24%   " Foreground="#2ECC71" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="TCB " Foreground="#1A1D2D" FontSize="11" FontWeight="Bold"/><TextBlock Text=" ↘ -0.58%   " Foreground="#EA5455" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="VIC " Foreground="#1A1D2D" FontSize="11" FontWeight="Bold"/><TextBlock Text=" ↗ +2.07%   " Foreground="#2ECC71" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Text="HPG " Foreground="#1A1D2D" FontSize="11" FontWeight="Bold"/><TextBlock Text=" ↘ -1.13%" Foreground="#EA5455" FontSize="11" FontWeight="Bold"/>
                            </WrapPanel>
                        </Grid>

                        <!-- Bar Chart Mock -->
                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Bar T1 -->
                            <Border x:Name="BarT1" Grid.Column="0" Background="#D8D4F5" CornerRadius="6,6,0,0" Margin="5,40,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="0" Text="T1" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>
                            
                            <!-- Bar T2 -->
                            <Border x:Name="BarT2" Grid.Column="1" Background="#D8D4F5" CornerRadius="6,6,0,0" Margin="5,30,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="1" Text="T2" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>

                            <!-- Bar T3 -->
                            <Border x:Name="BarT3" Grid.Column="2" Background="#D8D4F5" CornerRadius="6,6,0,0" Margin="5,50,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="2" Text="T3" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>

                            <!-- Bar T4 -->
                            <Border x:Name="BarT4" Grid.Column="3" Background="#D8D4F5" CornerRadius="6,6,0,0" Margin="5,20,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="3" Text="T4" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>

                            <!-- Bar T5 -->
                            <Border x:Name="BarT5" Grid.Column="4" Background="#D8D4F5" CornerRadius="6,6,0,0" Margin="5,25,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="4" Text="T5" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>

                            <!-- Bar T6 (Active) -->
                            <Border x:Name="BarT6" Grid.Column="5" Background="#6C5DD3" CornerRadius="6,6,0,0" Margin="5,0,5,0" VerticalAlignment="Bottom" Height="0"/>
                            <TextBlock Grid.Column="5" Text="T6" Foreground="#A0A0B0" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-20"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
