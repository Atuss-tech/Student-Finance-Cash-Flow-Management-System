<Window x:Class="WPF.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF.Views"
        xmlns:uc="clr-namespace:WPF.Views.UserControls"
        xmlns:utils="clr-namespace:WPF.Utils"
        xmlns:viewmodels="clr-namespace:WPF.ViewModels"
        mc:Ignorable="d"
        Title="FinanceOS" Height="850" Width="1440"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <utils:BoolToThemeIconConverter x:Key="BoolToThemeIconConverter"/>
        
        <ControlTemplate x:Key="ActiveSidebarButtonTemplate" TargetType="Button">
            <Grid>
                <Border Width="3" HorizontalAlignment="Left" Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="0,2,2,0" />
                <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="18,0" Margin="3,0,0,0">
                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                </Border>
            </Grid>
        </ControlTemplate>
        
        <Style x:Key="DynamicSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="260"/>
            <!-- Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" BorderThickness="0,0,1,0" BorderBrush="{DynamicResource CardBorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Margin="20,30,20,40">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Background="{DynamicResource PrimaryAccentBrush}" CornerRadius="8" Width="32" Height="32" BorderBrush="#8010d9a0" BorderThickness="1">
                            <Border.Effect>
                                <DropShadowEffect Color="{DynamicResource PrimaryAccent}" BlurRadius="15" Opacity="0.8" ShadowDepth="0"/>
                            </Border.Effect>
                            <TextBlock Text="🌟" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" Foreground="White" FontFamily="Segoe UI Emoji"/>
                        </Border>
                        <TextBlock Text="FinanceOS" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="White" BlurRadius="5" Opacity="0.3" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>
                
                <StackPanel Grid.Row="1" Margin="10,0">
                    <!-- Dashboard -->
                    <Button Command="{Binding ShowDashboardCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DynamicSidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ActiveSidebarButtonBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Template" Value="{StaticResource ActiveSidebarButtonTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Tổng quan" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Transactions -->
                    <Button Command="{Binding ShowTransactionsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DynamicSidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTransactionsActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ActiveSidebarButtonBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Template" Value="{StaticResource ActiveSidebarButtonTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💳" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Giao dịch" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Budgets -->
                    <Button Command="{Binding ShowBudgetsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DynamicSidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBudgetsActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ActiveSidebarButtonBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Template" Value="{StaticResource ActiveSidebarButtonTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Ngân sách" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- Reports -->
                    <Button Command="{Binding ShowReportsCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DynamicSidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReportsActive}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource ActiveSidebarButtonBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="Template" Value="{StaticResource ActiveSidebarButtonTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Báo cáo" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Toggle Theme -->
                    <Button Command="{Binding ToggleThemeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DynamicSidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDarkMode}" Value="True">
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IsDarkMode, Converter={StaticResource BoolToThemeIconConverter}}" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Đổi giao diện" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Settings -->
                    <Button Style="{StaticResource SidebarButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                            <TextBlock Text="Cài đặt" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User Profile Section -->
                <Button Grid.Row="2" Margin="20,0,20,30" Command="{Binding ShowProfileCommand}"
                        Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" 
                        BorderThickness="1" Cursor="Hand" HorizontalContentAlignment="Stretch">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" Padding="15">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="40" Height="40" Background="{DynamicResource ChartPurpleBrush}" CornerRadius="20" Margin="0,0,12,0">
                                        <TextBlock Text="NT" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="Nguyễn Thành" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="15" Margin="0,0,0,2"/>
                                        <TextBlock Text="Premium" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource HoverSidebarProfileBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource VioletAccentBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <!-- TopBar -->
                <RowDefinition Height="90"/>
                <!-- Main Content -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TopBar -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource CardBorderBrush}" Background="{DynamicResource AppBackgroundBrush}">
                <Grid Margin="30,0">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock Text="{Binding PageTitle}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding PageSubtitle}" FontSize="13" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Search Box -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="20" Padding="15,8" Width="250" Margin="0,0,20,0">
                            <Grid>
                                <TextBlock Text="🔍 Tìm kiếm..." Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        
                        <!-- Notification -->
                        <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="20" Width="40" Height="40" Margin="0,0,20,0">
                            <TextBlock Text="🔔" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- Add Transaction Button -->
                        <Button Content="+ Thêm giao dịch" Command="{Binding OpenTransactionDialogCommand}" Visibility="{Binding AddTransactionVisibility}" Background="{DynamicResource PrimaryAccentBrush}" Foreground="White" FontWeight="SemiBold" BorderThickness="0" Padding="20,10" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        
                        <!-- Create Budget Button -->
                        <Button Content="+ Tạo ngân sách" Command="{Binding OpenBudgetDialogCommand}" Visibility="{Binding AddBudgetVisibility}" Background="{DynamicResource PrimaryAccentBrush}" Foreground="{DynamicResource AppBackgroundBrush}" FontWeight="Bold" BorderThickness="0" Padding="20,10" Cursor="Hand" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Border Grid.Row="1" Padding="30,20,30,30">
                <ContentControl Content="{Binding CurrentView}" />
            </Border>
        </Grid>
    </Grid>
</Window>
