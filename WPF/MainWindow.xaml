<Window x:Class="Student_Finance___Cash_Flow_Management_System.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Student_Finance___Cash_Flow_Management_System"
        xmlns:dashboard="clr-namespace:WPF.Features.Dashboard"
        mc:Ignorable="d"
        Title="FinanceOS" Height="900" Width="1440"
        WindowStartupLocation="CenterScreen"
        Background="#f0f2f5"
        FontFamily="Segoe UI, Be Vietnam Pro, Inter, sans-serif">
    <Window.Resources>
                                <!-- Colors -->
        <SolidColorBrush x:Key="AppBackground" Color="#f0f2f5"/>
        <SolidColorBrush x:Key="SurfaceColor" Color="#ffffff"/>
        <SolidColorBrush x:Key="PrimaryBlue" Color="#0052ff"/>
        <SolidColorBrush x:Key="PrimaryBlueHover" Color="#003ecc"/>
        <SolidColorBrush x:Key="PrimaryGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryLightGreen" Color="#05b169"/>
        <SolidColorBrush x:Key="PrimaryRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="IncomeColor" Color="#05b169"/>
        <SolidColorBrush x:Key="IncomePurple" Color="#05b169"/>
        <SolidColorBrush x:Key="ExpenseColor" Color="#cf202f"/>
        <SolidColorBrush x:Key="ExpenseRed" Color="#cf202f"/>
        <SolidColorBrush x:Key="SavingsOrange" Color="#0052ff"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6b7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#e5e7eb"/>
        
        <!-- Styles -->
        <Style x:Key="SidebarItemStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,5,10,5"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ActiveIndicator" Width="4" HorizontalAlignment="Left" Background="{StaticResource PrimaryBlue}" CornerRadius="2" Visibility="Hidden" Margin="0,8,0,8"/>
                                <ContentPresenter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="Background" Value="#1A0052ff"/> <!-- Semi-transparent blue -->
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0" Background="{StaticResource AppBackground}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                </Grid.RowDefinitions>

                <!-- Logo Area -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <Border Width="32" Height="32" Background="{StaticResource PrimaryBlue}" CornerRadius="100" Margin="0,0,12,0">
                        <TextBlock Text="F" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="FinanceOS" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="22" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Row="1" Margin="10,0,10,0">
                    <RadioButton Content="Tổng quan" Style="{StaticResource SidebarItemStyle}" IsChecked="True" GroupName="Menu" Checked="Nav_Dashboard_Checked"/>
                    <RadioButton Content="Giao dịch" Style="{StaticResource SidebarItemStyle}" GroupName="Menu" Checked="Nav_Transactions_Checked"/>
                    <RadioButton Content="Ngân sách" Style="{StaticResource SidebarItemStyle}" GroupName="Menu" Checked="Nav_Budgets_Checked"/>
                    <RadioButton Content="Báo cáo" Style="{StaticResource SidebarItemStyle}" GroupName="Menu" Checked="Nav_Reports_Checked"/>
                    <RadioButton Content="Ví" Style="{StaticResource SidebarItemStyle}" GroupName="Menu" Checked="Nav_Wallets_Checked"/>
                    <RadioButton Content="Danh mục" Style="{StaticResource SidebarItemStyle}" GroupName="Menu" Checked="Nav_Categories_Checked"/>
                </StackPanel>

                <!-- User Profile Bottom -->
                <Border Grid.Row="2" Margin="20,0,20,20" Background="{StaticResource SurfaceColor}" CornerRadius="12" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="36" Height="36" Fill="#3131c0"/>
                        <TextBlock Text="NT" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Nguyễn Thành" Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold" FontSize="14"/>
                            <TextBlock Text="Premium" Foreground="{StaticResource TextSecondary}" FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- MAIN CONTENT AREA -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="32,0,32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitle" Text="Tổng quan tài chính" Foreground="{StaticResource TextPrimary}" FontWeight="Bold" FontSize="26" Margin="0,0,0,4"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Search Box -->
                    <Border Background="{StaticResource SurfaceColor}" CornerRadius="20" Width="260" Height="44" Margin="0,0,20,0" Padding="16,0,16,0">
                        <Grid>
                            <TextBlock Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                            <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center" Margin="24,0,0,0" FontSize="14" VerticalContentAlignment="Center" Text="Tìm kiếm..."/>
                        </Grid>
                    </Border>
                    
                    <!-- Notification Bell -->
                    <Border Width="44" Height="44" CornerRadius="22" Background="{StaticResource SurfaceColor}" Margin="0,0,20,0">
                        <TextBlock Text="🔔" Foreground="{StaticResource TextPrimary}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    
                    <!-- Global Add Button -->
                    <Button x:Name="GlobalAddButton" Height="44" Padding="24,0,24,0" Background="{StaticResource PrimaryBlue}" BorderThickness="0" Cursor="Hand" Click="GlobalAddButton_Click" Foreground="White" FontWeight="SemiBold" FontSize="15">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24,0,24,0">
                                        <TextBlock Text="+" FontSize="20" Foreground="White" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{TemplateBinding Content}" Foreground="White" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- DYNAMIC VIEW CONTAINER -->
            <!-- DashboardHomeView is loaded here temporarily for preview -->
            <ContentControl x:Name="MainContentControl" Grid.Row="1" Margin="32,0,32,32">
                <dashboard:DashboardHomeView />
            </ContentControl>
        </Grid>
    </Grid>
</Window>

